# Variables que la edge function lighthouse-report-builder espera en runtime.
# NUNCA commitear con valores reales. Ver SECRETS.md para cómo configurarlas.

# Auto-inyectadas por Supabase (no setear manualmente en producción)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API key de OpenRouter para llamadas al LLM
OPENROUTER_API_KEY=

# Header x-internal-secret que protege la función. Generá uno con: openssl rand -hex 32
LIGHTHOUSE_REPORT_INTERNAL_SECRET=

# Opcional. Default: anthropic/claude-sonnet-4
# Otras opciones: anthropic/claude-opus-4, anthropic/claude-haiku-4, openai/gpt-4-turbo
LIGHTHOUSE_REPORT_MODEL=anthropic/claude-sonnet-4

# Google Drive / Docs API (para lighthouse-google-docs-exporter)
# Reusan las mismas credenciales del proyecto freelancers
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_DOCS_REFRESH_TOKEN=

# Opcional. Default: "SeoLab Informes SEO"
LIGHTHOUSE_DRIVE_ROOT=SeoLab Informes SEO
