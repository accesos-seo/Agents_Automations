# ============================================================
# .env.example — seo_sentinel (variables de DEPLOY local)
# ============================================================
# Estas variables SOLO se usan localmente para correr deploy.py
# y herramientas de desarrollo. NO son los secretos de runtime.
#
# Los secretos de runtime (GSC_SERVICE_ACCOUNT_JSON, SLACK_BOT_TOKEN,
# etc.) van en Supabase Vault — ver SECRETS.md.
#
# Uso:
#   cp .env.example .env
#   # editar .env con los valores reales
#   python deploy.py
# ============================================================

# Project ref del Supabase de destino (Light_House)
SUPABASE_PROJECT_REF=stjugsrkrweakvzmizpq

# URL base del proyecto (sin slash final)
SUPABASE_URL=https://stjugsrkrweakvzmizpq.supabase.co

# Access token personal para el Supabase CLI (genera uno en
# https://supabase.com/dashboard/account/tokens y pegalo aca)
SUPABASE_ACCESS_TOKEN=PENDING_CONFIG

# URL de las edge functions (la usa el deploy script para verificar)
SUPABASE_FUNCTIONS_URL=https://stjugsrkrweakvzmizpq.functions.supabase.co

# Path al binario de Deno (si no esta en PATH, indicarlo aqui)
# DENO_BIN=C:/Users/<user>/.deno/bin/deno.exe
