# ============================================================================
# Plantilla de variables de entorno para la automatización.
# Copia este archivo a `.env` (en tu máquina local) y rellena los valores.
# El archivo `.env` NO se sube al repo (está en .gitignore).
# ============================================================================
#
# En PRODUCCIÓN estos mismos nombres se configuran como:
#   - Secretos de Supabase Functions:
#       supabase secrets set NOMBRE=valor
#   - Secretos de Supabase Vault (los que necesita pg_cron desde SQL):
#       ver `db/migrations/005_secrets_setup.sql`
# ============================================================================

# ---------- Conexión a Supabase ----------
# URL del proyecto. Aparece en el dashboard de Supabase.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Clave anon (pública, segura de exponer en frontend).
SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME

# Clave service_role (SECRETA, no exponer en frontend).
# Usada por las Edge Functions y por scripts administrativos.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME

# ---------- Mailjet (envío de correos) ----------
MAILJET_API_KEY=REPLACE_ME
MAILJET_SECRET_KEY=REPLACE_ME

# ---------- Google Drive / Docs (generación de Google Docs) ----------
# OAuth credentials. Se obtienen en Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=REPLACE_ME
# Refresh token con scope drive.file. Se obtiene una sola vez vía OAuth Playground.
GOOGLE_DOCS_REFRESH_TOKEN=1//REPLACE_ME

# ---------- Internas de la automatización ----------
# Header secreto que validan las Edge Functions cuando las invoca pg_cron.
# Generar uno largo y aleatorio (32+ caracteres).
FREELANCER_INVOICE_INTERNAL_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Remitente para los correos a freelancers.
FREELANCER_INVOICE_FROM_EMAIL=accesos@seolabagency.com
FREELANCER_INVOICE_FROM_NAME=SeoLab Agency — Cuentas de cobro

# URL base de la app frontend (para construir los links del correo).
FREELANCER_INVOICE_APP_BASE_URL=https://app.seolabagency.com

# Carpeta raíz en Google Drive donde se guardan las cuentas de cobro.
FREELANCER_INVOICE_DRIVE_ROOT=SeoLab Cuentas de cobro
