# seo-optimizer — local dev environment variables
# Copy to .env (gitignored) and fill in real values.
# In production, these are set as Railway env vars (see SECRETS.md).

# Supabase (Light_House project)
SUPABASE_URL=https://stjugsrkrweakvzmizpq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Internal auth between pg_cron and Railway endpoints
SEO_OPTIMIZER_INTERNAL_SECRET=

# Google Search Console
# Full JSON content of the Service Account key file (as a single-line string)
GSC_SERVICE_ACCOUNT_JSON=

# LLM
OPENROUTER_API_KEY=
SEO_OPTIMIZER_MODEL=anthropic/claude-sonnet-4.5

# Slack
SLACK_BOT_TOKEN=
SLACK_FALLBACK_CHANNEL=
SLACK_ADMIN_CHANNEL=

# Misc
LOG_LEVEL=INFO
