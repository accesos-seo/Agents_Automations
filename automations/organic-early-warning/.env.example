# ============================================================
# .env.example — Organic Early Warning + Data Hub
# ============================================================
# Variables LOCALES para correr deploy.py.
# Los secretos de runtime (API keys, tokens, etc.) viven en Supabase Vault
# — ver SECRETS.md. NUNCA poner secrets reales acá.
#
# Uso:
#   cp .env.example .env
#   # editar .env con los valores reales
#   python deploy.py
# ============================================================

# Project ref del Supabase de destino (Light_House)
SUPABASE_PROJECT_REF=stjugsrkrweakvzmizpq

# URL base del proyecto
SUPABASE_URL=https://stjugsrkrweakvzmizpq.supabase.co

# URL de las edge functions (la usa deploy.py para verificar deploys exitosos)
SUPABASE_FUNCTIONS_URL=https://stjugsrkrweakvzmizpq.functions.supabase.co

# Personal Access Token de Supabase (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=PENDING_CONFIG

# Path al binario de Deno (si no está en PATH)
# DENO_BIN=C:/Users/ceoel/.deno/bin/deno.exe

# Selector de qué desplegar:
#   "all"  → todas las 12 edge functions (5 hub + 7 oew)
#   "hub"  → solo las 5 del data hub
#   "oew"  → solo las 7 del organic early warning
# Lo podés overridear pasando como argumento a deploy.py
DEPLOY_TARGET=all
